{
  "name": "E-Commerce Basic",
  "domain": "microservices",
  "description": "Standard e-commerce platform with catalog, cart, and orders.",
  "features": ["User Authentication", "Product Catalog", "Shopping Cart", "Order Processing"],
  "constraints": ["Must use PostgreSQL", "Horizontal scalability needed"],
  "tech_stack": {
    "api_framework": "FastAPI",
    "database": "PostgreSQL",
    "cache": "Redis",
    "message_queue": "RabbitMQ"
  },
  "services": ["auth-service", "catalog-service", "cart-service", "order-service"],
  "rationale": "Separation of concerns allows independent scaling of catalog and order processing."
}
